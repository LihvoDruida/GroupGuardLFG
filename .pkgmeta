package-as: GroupGuardLFG

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - .git
  - .github
  - .vscode
  - .idea
  - screenshots
  - docs
  - tools
  - tests
  - node_modules
  - package.json
  - package-lock.json
  - pnpm-lock.yaml
  - yarn.lock
  - cliff.toml
  - CHANGELOG.md
  - README.md
  - README_CURSEFORGE.md
  - .editorconfig
  - .DS_Store
  - "*.psd"
  - "*.kra"
  - "*.blend"
